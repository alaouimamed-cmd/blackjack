# ============================================================================
# CONFIGURATION GÉNÉRALE - MA INVOICE (Maroc)
# ============================================================================

# Serveur
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ============================================================================
# BASE DE DONNÉES (PostgreSQL obligatoire pour ACID)
# ============================================================================
DATABASE_URL="postgresql://user:password@localhost:5432/ma_invoice?schema=public"

# ============================================================================
# AUTHENTIFICATION & SÉCURITÉ
# ============================================================================
JWT_SECRET=votre_secret_jwt_minimum_32_caracteres_tres_secu
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=votre_refresh_token_secret_minimum_32_chars
REFRESH_TOKEN_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# ============================================================================
# STOCKAGE FICHIERS (S3-compatible pour PDF/A-3)
# ============================================================================
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=eu-west-1
AWS_S3_BUCKET=ma-invoice-documents

# ============================================================================
# EMAIL (Optionnel - Notifications)
# ============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@yourcompany.ma
SMTP_PASSWORD=your_app_password

# ============================================================================
# CONFORMITÉ MAROCAINE
# ============================================================================
# Prefixe de numérotation des factures
INVOICE_PREFIX=FAC
# Année fiscale courante
FISCAL_YEAR=2025
# Timbre fiscal maximum (selon CGI marocain)
MAX_TIMBRE_FISCAL=1000
